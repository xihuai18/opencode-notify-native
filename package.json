{
  "name": "@leo000001/opencode-notify-native",
  "version": "1.4.0",
  "description": "OpenCode plugin for direct native notification center alerts",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node --input-type=commonjs -e \"const fs=require('fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('dist-test',{recursive:true,force:true}); for (const f of ['tsconfig.tsbuildinfo','tsconfig.build.tsbuildinfo','tsconfig.test.tsbuildinfo']) { try { fs.rmSync(f,{force:true}); } catch {} }\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "build:test": "tsc -p tsconfig.test.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build:test && node scripts/run-tests.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run build && npm test"
  },
  "keywords": [
    "opencode",
    "plugin",
    "notify",
    "notification",
    "native"
  ],
  "license": "MIT",
  "author": "xihuai18",
  "repository": {
    "type": "git",
    "url": "https://github.com/xihuai18/opencode-notify-native.git"
  },
  "homepage": "https://github.com/xihuai18/opencode-notify-native#readme",
  "bugs": {
    "url": "https://github.com/xihuai18/opencode-notify-native/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.2.10",
    "@opencode-ai/sdk": "^1.2.10"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.2.10",
    "@opencode-ai/sdk": "^1.2.10",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
